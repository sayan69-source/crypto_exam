# Centre Edge Server config (§13). LAN-only — never set a WAN address here.
EDGE_HOST=127.0.0.1
EDGE_PORT=4000

# Centre-scoped local PostgreSQL (matches docker-compose.yml).
DATABASE_URL=postgres://zuup:zuup@127.0.0.1:5433/zuup_edge

# This centre's id (UUID). Every query is scoped to it.
CENTRE_ID=00000000-0000-0000-0000-000000000000

# System Admin answer-sealing PUBLIC key (PEM, SPKI). Ships in the signed image.
# The matching PRIVATE key lives ONLY in the HQ HSM (INV-6). Leave blank on the
# Edge until provisioning; the answer pipeline refuses to seal without it.
SYSTEM_ADMIN_PUBLIC_KEY_PEM=

# Argon2id cost for one-time codes / DOB (§9.4). Production defaults shown.
ARGON_TIME_COST=3
ARGON_MEMORY_KIB=65536
ARGON_PARALLELISM=1
