# ZUUP-OS image-pipeline kernel fragment — merged AFTER kernel/zuup.config.
#
# zuup.config is the §7.2 hardening *policy*; this fragment is what an actual
# bootable image additionally needs: the UKI boot path, the dm-verity stack,
# kernel-side netfilter for security/nftables.conf, and the small closed set
# of built-in drivers (wired NICs, USB HID, QEMU virtio for the smoke boot).
#
# ── NO LOADABLE MODULES AT ALL ───────────────────────────────────────────────
# Strictly stronger than MODULE_SIG_FORCE: with CONFIG_MODULES=n there is no
# module loader to attack — every driver below is built in, and attack-matrix
# row 15 (rootkit module) becomes structurally impossible, not just signed-
# away. (The MODULE_SIG_* lines of zuup.config become no-ops under =n.)
# CONFIG_MODULES is not set

# ── UKI / UEFI boot path (§7.1) ──────────────────────────────────────────────
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_PARTITION=y
CONFIG_EFIVAR_FS=y
CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_FRAMEBUFFER_CONSOLE=y

# ── device-mapper core under DM_VERITY (§7.3) + PXE RAM payload path ────────
CONFIG_MD=y
CONFIG_BLK_DEV_DM=y
CONFIG_BLK_DEV_RAM=y
CONFIG_BLK_DEV_RAM_COUNT=2
CONFIG_BLK_DEV_RAM_SIZE=524288

# ── kernel side of security/nftables.conf (default-drop firewall, §6.3) ─────
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_CT=y
CONFIG_NFT_LOG=y
CONFIG_NFT_REJECT=y

# ── LSM stack: lockdown first, then yama + apparmor (§7.5) ──────────────────
CONFIG_SECURITY_YAMA=y
CONFIG_LSM="lockdown,yama,apparmor,bpf"

# ── the closed driver set (§7.2): wired NICs common in exam-hall fleets ─────
CONFIG_E1000=y
CONFIG_E1000E=y
CONFIG_IGB=y
CONFIG_IGC=y
CONFIG_R8169=y

# ── USB host + the allow-listed input/biometric classes (USBGuard pins the
#    rest at runtime; storage/printer/audio classes are compiled OUT) ────────
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y
CONFIG_MEDIA_SUPPORT=y
CONFIG_MEDIA_USB_SUPPORT=y
CONFIG_VIDEO_DEV=y

# ── QEMU smoke boot (image-build/40): virtio disk/net/gpu + std VGA ─────────
# Real Intel/AMD graphics for a hardware batch are enabled per-deployment
# (CONFIG_DRM_I915 / CONFIG_DRM_AMDGPU); they are too large for the default
# 15 MB bzImage budget and not needed to prove the image boots.
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_DRM_BOCHS=y

# ── build hygiene ────────────────────────────────────────────────────────────
# CONFIG_DEBUG_INFO is not set
# CONFIG_IKHEADERS is not set
