# ZUUP-OS hardened kernel configuration fragment (spec §7.2)
#
# Applied over a mainline 6.x defconfig with `merge_config.sh`. The goal is the
# smallest attack surface that can still drive an exam terminal: wired Ethernet,
# one display, keyboard/mouse, the webcam, the fingerprint reader, and TPM 2.0 —
# and NOTHING else. Target bzImage < 15 MB.
#
# This is a config artifact, not a script. It is consumed on the Linux build
# host (see build.sh) and never on the developer workstation.

# ── Confidentiality lockdown (blocks /dev/mem, kprobes, BPF-write, etc.) ─────
CONFIG_SECURITY=y
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY=y

# ── Signed modules only ─────────────────────────────────────────────────────
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_FORCE=y
CONFIG_MODULE_SIG_ALL=y
CONFIG_MODULE_SIG_SHA512=y

# ── Memory / exploit hardening ──────────────────────────────────────────────
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_SHUFFLE_PAGE_ALLOCATOR=y
CONFIG_DEBUG_WX=y
CONFIG_STRICT_KERNEL_RWX=y
CONFIG_STRICT_MODULE_RWX=y

# ── Remove dangerous capabilities ───────────────────────────────────────────
# CONFIG_KEXEC is not set
# CONFIG_KEXEC_FILE is not set
# CONFIG_HIBERNATION is not set
# CONFIG_USERFAULTFD is not set
# CONFIG_PROC_KCORE is not set
# CONFIG_DEVMEM is not set
# CONFIG_DEVKMEM is not set
# CONFIG_BPF_UNPRIV_DEFAULT_ON is not set
# CONFIG_USER_NS is not set
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_SECURITY_DMESG_RESTRICT=y

# ── TPM 2.0 (measured boot + remote attestation to the Edge, §7.1) ──────────
CONFIG_TCG_TPM=y
CONFIG_TCG_TIS=y
CONFIG_TCG_CRB=y
CONFIG_HW_RANDOM_TPM=y

# ── Storage integrity: dm-verity over the read-only SquashFS (§7.3) ─────────
CONFIG_DM_VERITY=y
CONFIG_DM_VERITY_VERIFY_ROOTHASH_SIG=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XZ=y
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y

# ── AppArmor (runtime allow-list, §7.5) ─────────────────────────────────────
CONFIG_SECURITY_APPARMOR=y
CONFIG_DEFAULT_SECURITY_APPARMOR=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# ── Devices we KEEP: wired Ethernet, KMS display, input, UVC webcam ─────────
CONFIG_NET=y
CONFIG_INET=y
CONFIG_ETHERNET=y
CONFIG_WIREGUARD=y
CONFIG_DRM=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y
CONFIG_USB_VIDEO_CLASS=y          # UVC webcam for face capture
CONFIG_USB_ACM=y                  # CDC-ACM fingerprint readers

# ── Devices we REMOVE: every exfiltration / smuggling path (§6.2, §2.1) ─────
# CONFIG_WLAN is not set          # no Wi-Fi
# CONFIG_WWAN is not set          # no cellular modems
# CONFIG_BT is not set            # no Bluetooth
# CONFIG_USB_STORAGE is not set   # USB stick yields no block device
# CONFIG_SND is not set           # no audio capture (earpiece smuggling)
# CONFIG_FIREWIRE is not set
# CONFIG_USB_PRINTER is not set
# CONFIG_PARPORT is not set
