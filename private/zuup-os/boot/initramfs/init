#!/bin/sh
# ZUUP-OS initramfs /init (spec §7.3) — the first userspace instruction.
#
# Runs from the signed UKI (so this script's bytes are themselves under the
# Secure Boot signature). Its ONLY job is to close the trust chain:
#
#   UEFI ─verified─▶ UKI ─carries─▶ zuup.roothash ─verifies─▶ SquashFS root
#
# and to make every writable path RAM-only before handing off to systemd.
# FAIL-CLOSED: any error path ends in poweroff -f. There is no rescue shell,
# no prompt, no fallback root — a terminal that cannot prove its rootfs
# integrity must not reach the Login Gate (INV-10).

# Build note (mkinitramfs.sh): /bin/sh here is busybox; veritysetup is the
# only external binary shipped. No mdev/udev — the devices used are static.

fail() {
  # Make the reason observable before halting: print to the console (not just
  # kmsg) and hold for 30s so it can be read/photographed on real hardware.
  # Still fail-closed — it powers off, it just doesn't vanish instantly.
  echo "ZUUP-OS BOOT HALT: $1" > /dev/kmsg 2>/dev/null
  echo "" > /dev/console 2>/dev/null
  echo "ZUUP-OS BOOT HALT: $1" > /dev/console 2>/dev/null
  echo "(halting in 30s)" > /dev/console 2>/dev/null
  sync
  /bin/busybox sleep 30 2>/dev/null
  poweroff -f
  exit 1 # unreachable
}

/bin/busybox mount -t proc     -o nosuid,nodev,noexec proc     /proc || fail "proc"
/bin/busybox mount -t sysfs    -o nosuid,nodev,noexec sysfs    /sys  || fail "sysfs"
/bin/busybox mount -t devtmpfs -o nosuid,noexec       devtmpfs /dev  || fail "devtmpfs"

# ── 1. the verity root hash travels INSIDE the signed UKI cmdline ──────────
ROOTHASH=""
for arg in $(cat /proc/cmdline); do
  case "$arg" in zuup.roothash=*) ROOTHASH="${arg#zuup.roothash=}" ;; esac
done
case "$ROOTHASH" in
  [0-9a-f][0-9a-f][0-9a-f][0-9a-f]*) [ ${#ROOTHASH} -eq 64 ] || fail "malformed roothash" ;;
  *) fail "no zuup.roothash on the signed cmdline" ;;
esac

# ── 2. the SquashFS + its verity tree arrive from PXE into RAM (/dev/ram0
#       is populated by the UKI's PXE loader stage; on disk-provisioned
#       terminals they are GPT partitions 2 and 3 of the image laid out by
#       image-build/30-make-image.sh). There is no udev here, so partitions
#       are resolved from sysfs by their fixed GPT index — misidentification
#       is harmless because a wrong device cannot match the signed root hash
#       and the boot HALTs at verity open. ──────────────────────────────────
find_part() { # $1 = GPT partition number → echoes candidate /dev nodes,
              # REMOVABLE parent (the USB) first, then others (QEMU/virtio).
  _rem=""; _any=""
  for b in /sys/class/block/*; do
    [ -r "$b/partition" ] || continue
    [ "$(cat "$b/partition")" = "$1" ] || continue
    _dev="/dev/$(basename "$b")"
    if [ "$(cat "$b/../removable" 2>/dev/null)" = "1" ]; then
      _rem="$_rem $_dev"
    else
      _any="$_any $_dev"
    fi
  done
  for d in $_rem $_any; do echo "$d"; done
}

# Real USB needs a few seconds to enumerate after the kernel brings up the
# controller (QEMU is instant). Wait/retry up to ~30s for BOTH the root and
# its verity tree to appear; removable (USB) candidates are preferred so we
# never grab the internal disk's like-numbered partition.
ROOTDEV=""; HASHDEV=""; _i=0
while [ "$_i" -lt 60 ]; do
  ROOTDEV="$(find_part 2 | head -n1)"
  HASHDEV="$(find_part 3 | head -n1)"
  [ -n "$ROOTDEV" ] && [ -b "$ROOTDEV" ] && [ -n "$HASHDEV" ] && [ -b "$HASHDEV" ] && break
  /bin/busybox sleep 0.5
  _i=$((_i + 1))
done

# PXE-into-RAM fallback only if the GPT partitions truly never showed up.
[ -n "$ROOTDEV" ] && [ -b "$ROOTDEV" ] || ROOTDEV=/dev/ram0
[ -n "$HASHDEV" ] && [ -b "$HASHDEV" ] || HASHDEV=/dev/ram1
[ -b "$ROOTDEV" ] || fail "no root device (USB partitions never enumerated)"

# ── 3. open the verity mapping: every 4K block is hash-checked on read; a
#       single flipped bit anywhere → I/O error → kernel panic → poweroff ────
# Absolute path: there is no /etc/profile here to set PATH, and the binary
# lives at a known location staged by mkinitramfs.sh.
/sbin/veritysetup open "$ROOTDEV" zuup-root "$HASHDEV" "$ROOTHASH" \
  --panic-on-corruption || fail "verity open (image does not match signed hash)"

/bin/busybox mount -t squashfs -o ro,nosuid,nodev /dev/mapper/zuup-root /newroot \
  || fail "squashfs mount"

# ── 4. RAM-only writable surfaces (INV-2). The real fstab (rootfs/overlay.
#       fstab) re-asserts these; mounting them here means even early systemd
#       cannot touch a persistent medium. ───────────────────────────────────
for d in tmp run var/log; do
  /bin/busybox mount -t tmpfs -o rw,nosuid,nodev,noexec,mode=0755 tmpfs "/newroot/$d" \
    || fail "tmpfs $d"
done

# ── 5. hand off. PID 1 becomes the signed image's systemd. ──────────────────
/bin/busybox mount --move /proc /newroot/proc 2>/dev/null
/bin/busybox mount --move /sys  /newroot/sys  2>/dev/null
/bin/busybox mount --move /dev  /newroot/dev  2>/dev/null
exec /bin/busybox switch_root /newroot /usr/lib/systemd/systemd
fail "switch_root returned"
