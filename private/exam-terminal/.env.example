# exam-terminal — environment variables
#
# Copy to .env.local for local development. The terminal will run with
# defaults if these are unset; they only matter when you point it at a
# non-default backend.

# CryptoExam Core backend, including the /api/v1 prefix.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Centre identifier this terminal belongs to. In production this is
# burned in at OS provisioning time; locally it can be any string.
# NEXT_PUBLIC_CENTRE_ID=DL-CTR-0142

# Hardware terminal identifier (TPM-derived in production).
# NEXT_PUBLIC_TERMINAL_ID=DL-CTR-0142-T17
