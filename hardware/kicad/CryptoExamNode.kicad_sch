    (property "Reference" "U3" (at 250 55 0))
    (property "Value" "NEO-M9N-00B" (at 250 60 0))
    (property "Footprint" "GPS:u-blox_NEO-M9N_LCC-24" (at 250 170 0))
    (property "Description" "u-blox multi-GNSS, GPS/GLONASS/BeiDou, 1PPS" (at 250 175 0))
    ;; Pins:
    ;; VCC (Pin 11)    -> +3.3V
    ;; GND (Pin 3,8,15)-> GND
    ;; TXD (Pin 18)    -> CM4 UART_RXD
    ;; RXD (Pin 19)    -> CM4 UART_TXD
    ;; TIMEPULSE (Pin 6)-> CM4 GPIO_17 (1PPS)
    ;; V_BCKP (Pin 12) -> 3V coin cell (RTC backup)
    ;; RF_IN (Pin 1)   -> SMA antenna connector
  )

