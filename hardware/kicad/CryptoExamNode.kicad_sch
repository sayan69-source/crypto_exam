  ;; ═══════════════════════════════════════════════
  ;; Power Section
  ;; ═══════════════════════════════════════════════

  (symbol (lib_id "power:+3V3") (at 50 25) (unit 1)
    (uuid "pwr-3v3-main")
    (property "Reference" "#PWR01" (at 50 22 0))
    (property "Value" "+3V3" (at 50 22 0))
  )

  (symbol (lib_id "power:GND") (at 50 175) (unit 1)
    (uuid "pwr-gnd-main")
    (property "Reference" "#PWR02" (at 50 178 0))
    (property "Value" "GND" (at 50 178 0))
  )

  ;; ═══════════════════════════════════════════════
  ;; U1: Raspberry Pi CM4 (100-pin board-to-board)
  ;; ═══════════════════════════════════════════════

  (symbol (lib_id "MCU_Module:RaspberryPi_CM4") (at 150 80) (unit 1)
    (uuid "u1-cm4")
    (property "Reference" "U1" (at 150 30 0))
    (property "Value" "CM4104032" (at 150 35 0))
    (property "Footprint" "Module:RaspberryPi_CM4_DDR4" (at 150 180 0))
    (property "Description" "Raspberry Pi CM4, 4GB RAM, 32GB eMMC, WiFi" (at 150 185 0))
    ;; Key Pins:
    ;; GPIO_SPI0_MOSI (Pin 36) -> TPM SPI MOSI
    ;; GPIO_SPI0_MISO (Pin 35) -> TPM SPI MISO
    ;; GPIO_SPI0_SCLK (Pin 34) -> TPM SPI CLK
    ;; GPIO_SPI0_CE0  (Pin 33) -> TPM CS
    ;; GPIO_SDA1      (Pin 3)  -> I2C SDA (ATECC608A, RTC)
    ;; GPIO_SCL1      (Pin 5)  -> I2C SCL (ATECC608A, RTC)
    ;; UART_TXD       (Pin 8)  -> GPS UART TX
    ;; UART_RXD       (Pin 10) -> GPS UART RX
    ;; GPIO_17        (Pin 11) -> GPS 1PPS
    ;; GPIO_27        (Pin 13) -> Tamper Mesh Interrupt
    ;; GPIO_22        (Pin 15) -> Status LED Data
    ;; GPIO_SPI1_MOSI (Pin 38) -> TFT SPI MOSI
    ;; GPIO_SPI1_SCLK (Pin 40) -> TFT SPI CLK
    ;; GPIO_SPI1_CE0  (Pin 36) -> TFT CS
    ;; GPIO_25        (Pin 22) -> TFT DC
    ;; GPIO_24        (Pin 18) -> TFT RST
    ;; ETH_CLK        -> LAN8720A REFCLK
    ;; ETH_TXD0/1     -> LAN8720A TXD
    ;; ETH_RXD0/1     -> LAN8720A RXD
  )

  ;; ═══════════════════════════════════════════════
  ;; U2: Infineon TPM 2.0 (SLB9670)
  ;; ═══════════════════════════════════════════════

  (symbol (lib_id "Security:SLB9670") (at 50 80) (unit 1)
    (uuid "u2-tpm")
    (property "Reference" "U2" (at 50 55 0))
    (property "Value" "SLB9670XQ20FW" (at 50 60 0))
    (property "Footprint" "Package_DFN_QFN:VQFN-32-1EP_5x5mm_P0.5mm" (at 50 170 0))
    (property "Description" "Infineon TPM 2.0, SPI, Common Criteria EAL4+" (at 50 175 0))
    ;; Pins:
    ;; VCC (Pin 1)     -> +3.3V via ferrite bead
    ;; GND (Pin 9,17)  -> GND
    ;; SPI_CLK (Pin 4) -> CM4 SPI0_SCLK
    ;; SPI_MOSI (Pin 5)-> CM4 SPI0_MOSI
    ;; SPI_MISO (Pin 6)-> CM4 SPI0_MISO
    ;; SPI_CS (Pin 7)  -> CM4 SPI0_CE0 (active low)
    ;; RST_N (Pin 14)  -> +3.3V via 10K pullup
    ;; PP (Pin 15)     -> GND (physical presence)
  )

  ;; ═══════════════════════════════════════════════
