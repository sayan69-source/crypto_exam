# ──────────────────────────────────────────────
# CryptoExam Core — Environment Configuration
# Copy to .env and fill in actual values
# ──────────────────────────────────────────────

# ── Database ──
DATABASE_URL=postgresql+asyncpg://ce:dev_secret@localhost:5432/cryptoexam
POSTGRES_DB=cryptoexam
POSTGRES_USER=ce
POSTGRES_PASSWORD=dev_secret

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Auth (RS256 JWT) ──
JWT_PRIVATE_KEY_PATH=./certs/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./certs/jwt_public.pem
JWT_ALGORITHM=RS256
JWT_EXPIRY_HOURS=4

# ── Blockchain (Polygon Amoy Testnet) ──
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_CHAIN_ID=80002
DEPLOYER_PRIVATE_KEY=<wallet_private_key>
CRYPTOEXAM_CONTRACT_ADDRESS=<deployed_address>
ZKVERIFIER_CONTRACT_ADDRESS=<deployed_address>

# ── Cryptography ──
DRAND_CHAIN_HASH=8990e7a9aaed2ffed73dbd7092123d6f289930540d7651336225dc172e51b2ce

# ── AI / LLM ──
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1:70b
OPENAI_API_KEY=<fallback_only>

# ── IPFS ──
IPFS_API_URL=http://localhost:5001

# ── hCaptcha (DPDP-compliant, NOT Google reCAPTCHA) ──
HCAPTCHA_SECRET_KEY=<key>
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=<key>

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Celery ──
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
